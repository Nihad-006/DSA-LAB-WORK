#include <iostream>
using namespace std;
int heap[100];
int n = 0;

void insert(int value) {
    n++;
    int i = n;
    heap[i] = value;
    while (i > 1 && heap[i] < heap[i / 2]) {
        swap(heap[i], heap[i / 2]);
        i /= 2;
    }
}

void heapify(int i) {
    int smallest = i;
    int left = 2 * i;
    int right = 2 * i + 1;
    if (left <= n && heap[left] < heap[smallest]) smallest = left;
    if (right <= n && heap[right] < heap[smallest]) smallest = right;
    if (smallest != i) {
        swap(heap[i], heap[smallest]);
        heapify(smallest);
    }
}

void deleteRoot() {
    if (n == 0) { cout << "Heap is empty\n"; return; }
    heap[1] = heap[n];
    n--;
    heapify(1);
}

void heapSort() {
    int size = n;
    while (n > 1) {
        swap(heap[1], heap[n]);
        n--;
        heapify(1);
    }
    cout << "Sorted Array (descending): ";
    for (int i = 1; i <= size; i++) cout << heap[i] << " ";
    cout << endl;
    n = size;
}

void display() {
    for (int i = 1; i <= n; i++) cout << heap[i] << " ";
    cout << endl;
}

int main() {
    insert(50); insert(30); insert(40); insert(10); insert(20);
    cout << "Min Heap: "; display();
    deleteRoot();
    cout << "After Delete: "; display();
    heapSort();
    return 0;
}
